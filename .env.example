TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
DATABASE_URL=sqlite:///./hr_bot.db
TIMEZONE=Europe/Moscow

# Demo mode for quick local checks
DEMO_MODE=true
DEMO_STEP_MINUTES=1
MANUAL_STEP_MINUTES=1

# Scenario settings
PROBATION_WORKDAYS=40
TEST_URL=https://example.com/test
PRACTICE_URL=https://example.com/practice
TASKS_URL=https://example.com/tasks
FEEDBACK_URL=https://example.com/feedback

# Local file storage
FILE_STORAGE_DIR=./storage/employee_files

# Admin panel session secret
ADMIN_SESSION_SECRET=change-me-admin-session-secret

# Default admin accounts created on startup
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_HR_LOGIN=hr
DEFAULT_HR_PASSWORD=hr123
